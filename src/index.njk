<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Xaver Friedrich</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body style="padding: var(--space-12) var(--space-8);">

    <p class="p-xs" style="letter-spacing: var(--letter-spacing-wider); text-transform: uppercase; margin-bottom: var(--space-12);">
      Phase 1 — Type Scale Preview
    </p>

    <h1>H1 — Tabular Medium Italic, 3.5rem fluid</h1>
    <h2>H2 — Tabular Medium Italic, 2.25rem fluid</h2>
    <h3>H3 — Tabular Medium Italic, 1.5rem fluid</h3>

    <hr />

    <p class="p-m-bold" style="margin-bottom: var(--space-4);">
      p—m-bold — Tabular Medium Italic, 1.25rem. Für Leads, Intros und Beschriftungen.
    </p>

    <p class="p-m">
      p—m — Tabular Regular, 1rem. Standard-Fließtext. Der Text bricht bei 44rem (ca. 700px) um — eine angenehme Lesebreite, kein Breakpoint nötig.
    </p>

    <p class="p-s" style="margin-top: var(--space-4);">
      p—s — Tabular Regular, 1rem, muted. Für sekundäre Inhalte, ergänzende Informationen.
    </p>

    <p class="p-xs" style="margin-top: var(--space-4);">
      p—xs — Tabular Light Italic, 0.875rem. Datum, Tags, Bildunterschriften, Metadaten.
    </p>

    <hr />

    <p class="p-m">
      <a href="#">Ein Link — underline-offset + thickness beim Hover</a>
    </p>

  </body>
</html>
