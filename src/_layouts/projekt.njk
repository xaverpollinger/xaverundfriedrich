---
layout: base.njk
bodyClass: page projekt-page
---

{# ── Platzhalter-Layout ─────────────────────────────────────────────────────
   Dieses Layout wird durch das neue Design ersetzt.
   Der Body-Content (inkl. [xf:...]-Shortcode-Blöcke) wird bereits korrekt
   gerendert und transformiert — nur das visuelle Wrapper-Design fehlt noch.    #}

<div class="container">
  <article class="projekt-detail">

    {# ── Meta-Header ── #}
    <header class="projekt-detail__header">
      {% if cover %}
        <img src="{{ cover }}" alt="{{ title }}" loading="eager">
      {% endif %}
      <h1>{{ title }}</h1>
      {% if description %}
        <p>{{ description }}</p>
      {% endif %}

      <dl>
        {% if year %}<div><dt>Jahr</dt><dd>{{ year }}</dd></div>{% endif %}
        {% if client %}<div><dt>Kunde</dt><dd>{{ client }}</dd></div>{% endif %}
        {% if role %}<div><dt>Rolle</dt><dd>{{ role }}</dd></div>{% endif %}
      </dl>

      {% if tags and tags.length %}
        <div>
          {% for tag in tags %}
            <span class="projekt-tag">{{ tag }}</span>
          {% endfor %}
        </div>
      {% endif %}
    </header>

    {# ── Body: Markdown + transformierte Shortcode-Blöcke ── #}
    <div class="projekt-detail__body">
      {{ content | safe }}
    </div>

  </article>
</div>

