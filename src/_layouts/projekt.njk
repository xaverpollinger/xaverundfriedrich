---
layout: base.njk
bodyClass: page projekt-page
---

{# ── Hero: Cover mit Titel-Overlay ── #}
<div class="projekt-hero-wrap">
  <div class="projekt-hero">
    {% if cover %}
      {% set coverSrc = cover | toSrcPath %}
      {% image coverSrc, title, "(min-width: 1152px) 1152px, 100vw" %}
    {% endif %}
    <div class="projekt-hero__gradient"></div>
    <div class="projekt-hero__title-wrap">
      <h1 class="projekt-hero__title">{{ title }}</h1>
    </div>
  </div>
</div>

<div class="container">
  <article class="projekt-detail">

    {# ── Intro: Kurzbeschreibung links, Meta rechts ── #}
    <div class="projekt-detail__intro">

      <div class="projekt-detail__intro-left">
        {% if description %}
          <p class="p-m-bold">{{ description }}</p>
        {% endif %}
      </div>

      <div class="projekt-detail__intro-right">
        <dl class="projekt-detail__meta">
          {% if year %}
            <div><dt>Jahr</dt><dd>{{ year }}</dd></div>
          {% endif %}
          {% if client %}
            <div><dt>Kunde</dt><dd>{{ client }}</dd></div>
          {% endif %}
          {% if role or (tags and tags.length) %}
            <div>
              <dt>Keywords</dt>
              <dd>{% set allKeywords = [] %}{% if role %}{% set allKeywords = allKeywords.concat(role.split(", ")) %}{% endif %}{% if tags and tags.length %}{% set allKeywords = allKeywords.concat(tags) %}{% endif %}{{ allKeywords | join(", ") }}</dd>
            </div>
          {% endif %}
        </dl>
      </div>

    </div>

    {# ── Body: Markdown + transformierte [xf:...]-Shortcode-Blöcke ── #}
    {% if content | trim %}
      <div class="projekt-detail__body">
        {{ content | safe }}
      </div>
    {% endif %}

  </article>
</div>
