<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="{{ description or 'Xaver Friedrich — UX/UI Designer' }}" />
    <title>{% if title %}{{ title }} — {% endif %}Xaver Friedrich</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body class="{{ bodyClass or 'page' }}">

    <header class="site-header">
      <nav class="site-nav" aria-label="Hauptnavigation">
        <ul role="list">
          {% for item in nav %}
            <li>
              <a href="{{ item.url }}"
                 {% if page.url == item.url %}aria-current="page"{% endif %}>
                {{ item.label }}
              </a>
            </li>
          {% endfor %}
        </ul>
      </nav>
    </header>

    <main id="main-content">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <nav aria-label="Rechtliche Links">
        <ul role="list">
          {% for item in legal %}
            <li>
              <a href="{{ item.url }}">{{ item.label }}</a>
            </li>
          {% endfor %}
        </ul>
      </nav>
    </footer>

  </body>
</html>
