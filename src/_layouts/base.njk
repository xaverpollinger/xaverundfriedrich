<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    {# --- Titel & Description --- #}
    <title>{% if title %}{{ title }} — {% endif %}{{ site.title }}</title>
    <meta name="description" content="{{ description or site.description }}" />
    <link rel="canonical" href="{{ site.url }}{{ page.url }}" />

    {# --- Favicon --- #}
    <link rel="icon" type="image/png" href="/assets/xundf_favicon.png" />

    {# --- Open Graph --- #}
    <meta property="og:type"        content="{% if layout == 'post.njk' %}article{% else %}website{% endif %}" />
    <meta property="og:title"       content="{% if title %}{{ title }} — {% endif %}{{ site.title }}" />
    <meta property="og:description" content="{{ description or site.description }}" />
    <meta property="og:url"         content="{{ site.url }}{{ page.url }}" />

    {# --- Twitter / X Card --- #}
    <meta name="twitter:card"        content="summary" />
    <meta name="twitter:title"       content="{% if title %}{{ title }} — {% endif %}{{ site.title }}" />
    <meta name="twitter:description" content="{{ description or site.description }}" />

    {# --- Theme Color (Browser-Chrome auf Mobil) --- #}
    <meta name="theme-color" content="#ffffff" />

    {# --- Font Preload: Schriften sofort laden, kein FOUT --- #}
    <link rel="preload" href="/fonts/Tabular-Variable.woff2"
          as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Tabular-VariableItalic.woff2"
          as="font" type="font/woff2" crossorigin />

    {# --- RSS Feed Discovery --- #}
    <link rel="alternate" type="application/rss+xml"
          title="{{ site.title }} — Blog" href="{{ site.url }}/feed.xml" />

    {# --- CSS inline: kein render-blocking, kein extra Request --- #}
    <style>{% inlineCSS %}</style>

    {# --- Construction Mode: sync laden (kein defer), verhindert Flash --- #}
    <script src="/js/dev-mode.js"></script>
  </head>

  <body class="{{ bodyClass or 'page' }}">

    {# Skip-Link: für Tastatur- und Screenreader-Navigation --- #}
    <a class="skip-link" href="#main-content">Zum Inhalt springen</a>

    <header class="site-header">
      <nav class="site-nav" aria-label="Hauptnavigation">

        {# Linke Seite: Logo #}
        <div class="nav-left">
          <a href="/" class="nav-logo" aria-label="Startseite">
            {% include "icons/xundf.svg" %}
          </a>
        </div>

        {# Mitte: Hauptnavigation — zentriert via Grid (Desktop) #}
        <ul role="list">
          {% for item in nav %}
            <li>
              <a href="{{ item.url }}"
                 {% if page.url == item.url %}aria-current="page"{% endif %}>
                {{ item.label }}
              </a>
            </li>
          {% endfor %}
        </ul>

        {# Rechte Seite: Social Icons (Desktop) + Burger (Mobile) #}
        <div class="nav-right">
          <a href="https://dribbble.com/xaverpollinger" class="nav-icon-link nav-desktop-only" aria-label="Dribbble" target="_blank" rel="noopener">
            {% include "icons/dribbble.svg" %}
          </a>
          <a href="https://www.linkedin.com/in/xaver-pollinger-24a02425b" class="nav-icon-link nav-desktop-only" aria-label="LinkedIn" target="_blank" rel="noopener">
            {% include "icons/social-linkedin.svg" %}
          </a>
          <a href="mailto:info@xaverfriedrich.de" class="nav-icon-link nav-desktop-only" aria-label="E-Mail senden">
            {% include "icons/mail.svg" %}
          </a>

          {# Burger-Button — nur auf Mobile sichtbar #}
          <button class="nav-burger" aria-label="Menü öffnen" aria-expanded="false" aria-controls="nav-mobile-menu">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="0 0 256 256" aria-hidden="true">
              <path d="M224,128a8,8,0,0,1-8,8H40a8,8,0,0,1,0-16H216A8,8,0,0,1,224,128ZM40,72H216a8,8,0,0,0,0-16H40a8,8,0,0,0,0,16ZM216,184H40a8,8,0,0,0,0,16H216a8,8,0,0,0,0-16Z"></path>
            </svg>
          </button>
        </div>

      </nav>

      {# Mobile Menü — klappt von oben über den Content #}
      <div class="nav-mobile-menu" id="nav-mobile-menu" aria-hidden="true">
        <ul role="list">
          {% for item in nav %}
            <li>
              <a href="{{ item.url }}"
                 {% if page.url == item.url %}aria-current="page"{% endif %}>
                {{ item.label }}
              </a>
            </li>
          {% endfor %}
        </ul>
        <div class="nav-mobile-menu__social">
          <a href="https://dribbble.com/xaverpollinger" class="nav-icon-link" aria-label="Dribbble" target="_blank" rel="noopener">
            {% include "icons/dribbble.svg" %}
          </a>
          <a href="https://www.linkedin.com/in/xaver-pollinger-24a02425b" class="nav-icon-link" aria-label="LinkedIn" target="_blank" rel="noopener">
            {% include "icons/social-linkedin.svg" %}
          </a>
          <a href="mailto:info@xaverfriedrich.de" class="nav-icon-link" aria-label="E-Mail senden">
            {% include "icons/mail.svg" %}
          </a>
        </div>
      </div>

    </header>

    <main id="main-content">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <nav class="legal-nav" aria-label="Rechtliche Links">
        {% for item in legal %}
          <a href="{{ item.url }}">{{ item.label }}</a>
        {% endfor %}
      </nav>
    </footer>

    {# Back-to-top Button — erscheint automatisch auf langen Seiten #}
    <button class="back-to-top" aria-label="Zurück nach oben" hidden>
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="0 0 256 256" aria-hidden="true">
        <path d="M205.66,117.66a8,8,0,0,1-11.32,0L136,59.31V216a8,8,0,0,1-16,0V59.31L61.66,117.66a8,8,0,0,1-11.32-11.32l72-72a8,8,0,0,1,11.32,0l72,72A8,8,0,0,1,205.66,117.66Z"></path>
      </svg>
    </button>

    {# Custom Cursor — auf allen Seiten aktiv #}
    <div id="cursorDot" aria-hidden="true"></div>
    <script src="/js/cursor.js" defer></script>

    {# Mobile Nav — auf allen Seiten aktiv #}
    <script src="/js/nav.js" defer></script>

    {# Back-to-top Logik #}
    <script>
      (function () {
        var btn = document.querySelector(".back-to-top");
        if (!btn) return;
        var PAGE_MIN  = 1500; // px — erst ab dieser Seitenhöhe aktiv
        var SCROLL_MIN = 750; // px — erst ab hier einblenden
        if (document.body.scrollHeight < PAGE_MIN) return;
        btn.removeAttribute("hidden");
        window.addEventListener("scroll", function () {
          if (window.scrollY > SCROLL_MIN) {
            btn.classList.add("is-visible");
          } else {
            btn.classList.remove("is-visible");
          }
        }, { passive: true });
        btn.addEventListener("click", function () {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      })();
    </script>

    {# Lazy-Image Fade: is-loaded Klasse sobald Bild geladen #}
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll("img[loading='lazy']").forEach(function (img) {
          if (img.complete) {
            img.classList.add("is-loaded");
          } else {
            img.addEventListener("load", function () {
              img.classList.add("is-loaded");
            });
          }
        });
      });
    </script>

    {# Seitenspezifische Scripts — nur laden wenn im Frontmatter definiert #}
    {% if scripts %}
      {% for src in scripts %}
        <script src="{{ src }}" defer></script>
      {% endfor %}
    {% endif %}

    {# ── Shortcode-Komponenten JS ──────────────────────────────────────────
       Läuft nur wenn xf-Komponenten auf der Seite vorhanden sind.
       Behandelt: [xf:video] Consent und [xf:slider] Interaktion.              #}
    <script>
    (function () {

      // ── xf:video Consent ────────────────────────────────────────────────
      // Ersetzt Consent-Button durch iframe sobald Nutzer klickt.
      document.querySelectorAll('.xf-video__consent').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var src = btn.getAttribute('data-src');
          var iframe = document.createElement('iframe');
          iframe.src = src + '?autoplay=1';
          iframe.title = 'Video';
          iframe.setAttribute('frameborder', '0');
          iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture');
          iframe.setAttribute('allowfullscreen', '');
          btn.replaceWith(iframe);
        });
      });

      // ── xf:summary ──────────────────────────────────────────────────────
      //
      // Desktop (≥640px): 2-Spalten-Grid. Slot-Höhen fixiert, paddingTop
      //   = activeIndex × slotH → Panel fluchtet mit Tab.
      //
      // Mobile (<640px): Tab-Track slidet horizontal (translateX).
      //   Aktiver Tab immer an Position 0 (linker Rand).
      //   Tab-Größe bleibt identisch → Track-Höhe konstant.

      document.querySelectorAll('[data-summary]').forEach(function (summary) {
        var tabs     = Array.from(summary.querySelectorAll('.xf-summary__tab'));
        var panels   = Array.from(summary.querySelectorAll('.xf-summary__panel'));
        var panelsEl = summary.querySelector('.xf-summary__panels');
        var track    = summary.querySelector('.xf-summary__track');
        var slotH    = 0;
        var BP       = 640;

        function isMobile() { return window.innerWidth < BP; }

        // ── Desktop: Slot-Höhen fixieren ──
        function setupDesktop() {
          track.style.transform = '';
          tabs.forEach(function (t) { t.style.height = ''; });
          panelsEl.style.paddingTop = '';

          var activeTab = tabs.find(function (t) { return t.classList.contains('is-active'); }) || tabs[0];
          var h = activeTab.offsetHeight;
          tabs.forEach(function (t) { t.style.height = h + 'px'; });
          var idx = tabs.indexOf(activeTab);
          panelsEl.style.paddingTop = (idx * h) + 'px';
          return h;
        }

        // ── Mobile: Tab-Reihenfolge im DOM neu setzen ──
        // Aktives Tab zuerst, dann die restlichen zirkulär in Originalreihenfolge.
        // Kein translateX nötig — das aktive Tab sitzt immer an Position 0.
        function reorderMobile(idx) {
          var n = tabs.length;
          for (var i = 0; i < n; i++) {
            track.appendChild(tabs[(idx + i) % n]);
          }
          track.style.transform = '';
        }

        function activate(idx) {
          tabs.forEach(function (t, i) { t.classList.toggle('is-active', i === idx); });
          panels.forEach(function (p, i) {
            if (i === idx) { p.removeAttribute('hidden'); }
            else           { p.setAttribute('hidden', ''); }
          });

          if (isMobile()) {
            reorderMobile(idx);
            panelsEl.style.paddingTop = '';
          } else {
            track.style.transform = '';
            panelsEl.style.paddingTop = (idx * slotH) + 'px';
          }
        }

        tabs.forEach(function (btn, i) {
          btn.addEventListener('click', function () { activate(i); });
        });

        var trackWrap = summary.querySelector('.xf-summary__track-wrap');

        function init() {
          // Maximale Track-Höhe einmalig messen (aktiver Tab = h2-Zustand = größter Zustand)
          // + 16px Puffer → min-height auf beiden Viewports fixieren.
          // Kein Springen mehr egal welcher Tab aktiv ist.
          trackWrap.style.minHeight = '';
          var activeTab = tabs.find(function (t) { return t.classList.contains('is-active'); }) || tabs[0];
          trackWrap.style.minHeight = (activeTab.offsetHeight + 16) + 'px';

          if (isMobile()) {
            tabs.forEach(function (t) { t.style.height = ''; });
            slotH = 0;
          } else {
            slotH = setupDesktop();
          }
        }

        if (document.fonts && document.fonts.ready) {
          document.fonts.ready.then(init);
        } else {
          init();
        }

        window.addEventListener('resize', init, { passive: true });
      });

      // ── xf:slider ───────────────────────────────────────────────────────
      document.querySelectorAll('[data-slider]').forEach(function (slider) {
        var track  = slider.querySelector('.xf-slider__track');
        var slides = slider.querySelectorAll('.xf-slider__slide');
        var prev   = slider.querySelector('.xf-slider__arrow--prev');
        var next   = slider.querySelector('.xf-slider__arrow--next');
        var dots   = slider.querySelectorAll('.xf-slider__dot');
        var n      = slides.length;
        var idx    = 0;

        if (n <= 1) {
          if (prev) prev.style.display = 'none';
          if (next) next.style.display = 'none';
          return;
        }

        function goTo(i) {
          idx = ((i % n) + n) % n;
          track.style.transform = 'translateX(-' + idx * 100 + '%)';
          dots.forEach(function (d, di) {
            d.classList.toggle('is-active', di === idx);
          });
        }

        if (prev) prev.addEventListener('click', function () { goTo(idx - 1); });
        if (next) next.addEventListener('click', function () { goTo(idx + 1); });

        dots.forEach(function (d, di) {
          d.addEventListener('click', function () { goTo(di); });
        });

        // Touch-Swipe
        var touchX = 0;
        track.addEventListener('touchstart', function (e) { touchX = e.touches[0].clientX; }, { passive: true });
        track.addEventListener('touchend', function (e) {
          var diff = touchX - e.changedTouches[0].clientX;
          if (Math.abs(diff) > 40) goTo(diff > 0 ? idx + 1 : idx - 1);
        });

        // Tastatur (nur wenn Slider fokussiert)
        slider.setAttribute('tabindex', '0');
        slider.addEventListener('keydown', function (e) {
          if (e.key === 'ArrowLeft')  goTo(idx - 1);
          if (e.key === 'ArrowRight') goTo(idx + 1);
        });
      });

    }());
    </script>

  </body>
</html>
