---
layout: base.njk
bodyClass: page post-page
---

<div class="container">
  <article class="projekt-detail">

    {# ── Header: Meta-Zeile + Titel ── #}
    <header class="post-header">
      <p class="post-header__meta">
        {%- set metaParts = [] -%}
        {%- if date -%}{%- set metaParts = metaParts.concat([date | dateReadable]) -%}{%- endif -%}
        {%- if tags and tags.length -%}{%- set metaParts = metaParts.concat(tags) -%}{%- endif -%}
        {{ metaParts | join(" · ") }}
      </p>
      <h1 class="post-header__title">{{ title }}</h1>
      {% if description %}
        <p class="post-header__desc p-m-bold">{{ description }}</p>
      {% endif %}
    </header>

    {# ── Body: Markdown + transformierte [xf:...]-Shortcode-Blöcke ── #}
    {% if content | trim %}
      <div class="projekt-detail__body">
        {{ content | safe }}
      </div>
    {% endif %}

  </article>
</div>
